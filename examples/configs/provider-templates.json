{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Provider 模板示例 —— 用于 hermes UI 的'一键添加 Provider'功能。详见 docs/06-engineering/04-provider-template.md",
  "version": "1.0",
  "providers": [
    {
      "id": "deepseek",
      "name": "DeepSeek",
      "icon": "🐋",
      "category": "cn",
      "baseUrl": "https://api.deepseek.com/v1",
      "defaultModel": "deepseek-chat",
      "models": ["deepseek-chat", "deepseek-reasoner"],
      "keyFormat": "sk-...",
      "applyUrl": "https://platform.deepseek.com/api_keys",
      "docsUrl": "https://platform.deepseek.com/",
      "description": "国内直连，性价比之王"
    },
    {
      "id": "alibaba",
      "name": "通义千问（阿里云）",
      "icon": "☁️",
      "category": "cn",
      "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "defaultModel": "qwen-plus",
      "models": ["qwen-plus", "qwen-turbo", "qwen-max", "qwen3-72b-instruct"],
      "keyFormat": "sk-...",
      "applyUrl": "https://bailian.console.aliyun.com/?apiKey=1",
      "docsUrl": "https://help.aliyun.com/zh/dashscope/",
      "description": "长上下文，官方稳定"
    },
    {
      "id": "moonshot",
      "name": "Kimi（Moonshot）",
      "icon": "🌙",
      "category": "cn",
      "baseUrl": "https://api.moonshot.cn/v1",
      "defaultModel": "moonshot-v1-auto",
      "models": ["moonshot-v1-8k", "moonshot-v1-32k", "moonshot-v1-128k", "moonshot-v1-auto"],
      "keyFormat": "sk-...",
      "applyUrl": "https://platform.moonshot.cn/console/api-keys",
      "description": "128k/200k 长上下文"
    },
    {
      "id": "zhipu",
      "name": "智谱 GLM",
      "icon": "🧠",
      "category": "cn",
      "baseUrl": "https://open.bigmodel.cn/api/paas/v4",
      "defaultModel": "glm-4-plus",
      "models": ["glm-4-plus", "glm-4", "glm-4-flash", "glm-4v"],
      "keyFormat": "...",
      "applyUrl": "https://bigmodel.cn/usercenter/apikeys",
      "description": "中文好，多模态"
    },
    {
      "id": "minimax",
      "name": "MiniMax",
      "icon": "🌀",
      "category": "cn",
      "baseUrl": "https://api.minimax.chat/v1",
      "defaultModel": "MiniMax-Text-01",
      "models": ["MiniMax-Text-01", "abab6.5s-chat"],
      "keyFormat": "eyJhbGciOi...",
      "applyUrl": "https://platform.minimaxi.com/user-center/basic-information/interface-key",
      "description": "角色扮演 / 客服 bot 强"
    },
    {
      "id": "baidu",
      "name": "百度文心（千帆）",
      "icon": "📚",
      "category": "cn",
      "baseUrl": "https://qianfan.baidubce.com/v2",
      "defaultModel": "ernie-4.0-turbo-8k",
      "models": ["ernie-4.0-turbo-8k", "ernie-speed-128k", "ernie-lite-8k"],
      "keyFormat": "bce-v3/ALTAK-xxx",
      "applyUrl": "https://console.bce.baidu.com/iam/#/iam/apikey/list",
      "description": "大厂背书，企业合规"
    },
    {
      "id": "openai",
      "name": "OpenAI",
      "icon": "🌐",
      "category": "oversea",
      "baseUrl": "https://api.openai.com/v1",
      "defaultModel": "gpt-4o",
      "models": ["gpt-4o", "gpt-4o-mini", "gpt-4-turbo", "o1-preview", "o1-mini"],
      "keyFormat": "sk-proj-... / sk-...",
      "applyUrl": "https://platform.openai.com/api-keys",
      "needsProxy": true,
      "description": "工具调用最稳"
    },
    {
      "id": "anthropic",
      "name": "Anthropic Claude",
      "icon": "🎭",
      "category": "oversea",
      "baseUrl": "https://api.anthropic.com/v1",
      "defaultModel": "claude-sonnet-4-5",
      "models": ["claude-sonnet-4-5", "claude-opus-4-5", "claude-haiku-4-5"],
      "keyFormat": "sk-ant-...",
      "applyUrl": "https://console.anthropic.com/settings/keys",
      "needsProxy": true,
      "transport": "anthropic_messages",
      "description": "编程 / 长文本 / 推理强"
    },
    {
      "id": "google",
      "name": "Google Gemini",
      "icon": "💎",
      "category": "oversea",
      "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
      "defaultModel": "gemini-2.0-flash",
      "models": ["gemini-2.0-flash", "gemini-2.0-pro", "gemini-1.5-pro"],
      "keyFormat": "AIza...",
      "applyUrl": "https://aistudio.google.com/apikey",
      "needsProxy": true,
      "description": "多模态 / 1M+ 上下文 / 部分免费"
    },
    {
      "id": "openrouter",
      "name": "OpenRouter（聚合 300+）",
      "icon": "🛣️",
      "category": "oversea",
      "baseUrl": "https://openrouter.ai/api/v1",
      "defaultModel": "openai/gpt-4o-mini",
      "models": ["openai/gpt-4o", "anthropic/claude-sonnet-4-5", "deepseek/deepseek-chat", "meta-llama/llama-3.3-70b-instruct"],
      "keyFormat": "sk-or-v1-...",
      "applyUrl": "https://openrouter.ai/settings/keys",
      "needsProxy": true,
      "description": "一个 key 接 300+ 模型"
    },
    {
      "id": "ollama",
      "name": "Ollama（本地模型）",
      "icon": "🦙",
      "category": "local",
      "baseUrl": "http://127.0.0.1:11434/v1",
      "defaultModel": "qwen2.5:7b",
      "models": ["qwen2.5:7b", "qwen2.5:14b", "deepseek-r1:7b", "llama3.2:3b"],
      "keyFormat": "（本地不需 key）",
      "applyUrl": "https://ollama.com/download",
      "docsUrl": "https://ollama.com/library",
      "isLocal": true,
      "defaultKey": "ollama",
      "description": "完全本地，0 token 费"
    }
  ]
}
