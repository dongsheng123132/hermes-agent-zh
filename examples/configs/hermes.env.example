# hermes-agent · 配置示例（.env 格式）
#
# 使用方式：复制本文件到 ~/.u-hermes/data/.env（或你设的 HERMES_HOME），编辑取消注释一行
# 至少要有一个 *_API_KEY 才能启动 hermes。
#
# ═══════════════════════════════════════════════════════════════
# 国产云（国内直连，不需代理）
# ═══════════════════════════════════════════════════════════════

# DeepSeek · 性价比之王（推荐）
# 申请: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-xxx

# 阿里云通义千问
# 申请: https://bailian.console.aliyun.com/?apiKey=1
# DASHSCOPE_API_KEY=sk-xxx

# 月之暗面 Kimi
# 申请: https://platform.moonshot.cn/console/api-keys
# MOONSHOT_API_KEY=sk-xxx

# 智谱 GLM
# 申请: https://bigmodel.cn/usercenter/apikeys
# ZHIPUAI_API_KEY=xxx

# 百度文心（千帆）
# 申请: https://console.bce.baidu.com/iam/#/iam/apikey/list
# QIANFAN_API_KEY=bce-v3/ALTAK-xxx

# ═══════════════════════════════════════════════════════════════
# 海外（需要代理才能访问）
# ═══════════════════════════════════════════════════════════════

# OpenAI GPT
# OPENAI_API_KEY=sk-proj-xxx

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-xxx

# Google Gemini
# GOOGLE_API_KEY=AIza...

# OpenRouter（聚合 300+ 模型，一个 key 全搞定）
# OPENROUTER_API_KEY=sk-or-v1-xxx

# ═══════════════════════════════════════════════════════════════
# 本地 Ollama
# ═══════════════════════════════════════════════════════════════
# 先安装 ollama: curl -fsSL https://ollama.com/install.sh | sh
# 下载模型: ollama pull qwen2.5:7b
# 然后取消下面两行注释（hermes 用 OpenAI 兼容协议接 ollama）
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# ═══════════════════════════════════════════════════════════════
# 代理配置（如果用海外 provider）
# ═══════════════════════════════════════════════════════════════
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# ═══════════════════════════════════════════════════════════════
# 回环白名单（必须保留，否则 hermes 把本地请求也走代理会卡死）
# ═══════════════════════════════════════════════════════════════
NO_PROXY=127.0.0.1,localhost,::1
no_proxy=127.0.0.1,localhost,::1
